generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                    @id @default(autoincrement())
  name                String
  email               String                 @unique
  password_hash       String
  role                String
  reliability_score   Int                    @default(100)
  quality_score       Int                    @default(100)
  total_earnings      Float                  @default(0)
  reputation          Float                  @default(3.0)
  total_reviews       Int                    @default(0)
  wallet_balance      Float                  @default(0)
  skills              Json?
  education           String?
  is_student          Boolean                @default(false)
  daily_hour_limit    Int                    @default(4)
  weekly_hour_limit   Int                    @default(20)
  created_at          DateTime               @default(now())
  jobs                Job[]
  escrows             Escrow[]
  workerEntities      WorkerEntity[]
  availabilities      Availability[]
  workerGroupMembers  WorkerGroupMember[]
  auctionBids         AuctionBid[]
  workerSchedules     WorkerSchedule[]
  paymentTransactions PaymentTransaction[]
  withdrawalRequests  WithdrawalRequest[]
}

model Job {
  id                   Int            @id @default(autoincrement())
  title                String
  description          String
  base_price           Float
  current_price        Float
  pricing_mode         String
  deadline             DateTime
  work_mode            String
  ai_allowed           Boolean
  question_file_url    String?
  submission_file_url  String?
  status               String         @default("open")
  urgent_status        Boolean        @default(false)
  extension_count      Int            @default(0)
  max_extensions       Int            @default(3)
  auction_mode         Boolean        @default(false)
  auction_end          DateTime?
  rated                Boolean        @default(false)
  auto_group           Boolean        @default(false)
  required_group_size  Int?
  estimated_hours      Int
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt
  client_id            Int
  client               User           @relation(fields: [client_id], references: [id])
  escrow               Escrow?
  workerEntity         WorkerEntity?
  auctionBids          AuctionBid[]
}

model Escrow {
  id            Int      @id @default(autoincrement())
  job_id        Int      @unique
  locked_amount Float
  status        String
  locked        Boolean  @default(true)
  created_at    DateTime @default(now())
  client_id     Int
  client        User     @relation(fields: [client_id], references: [id])
  job           Job      @relation(fields: [job_id], references: [id])
}

model WorkerEntity {
  id               Int                  @id @default(autoincrement())
  job_id           Int                  @unique
  type             String
  leader_id        Int
  status           String
  created_at       DateTime             @default(now())
  leader           User                 @relation(fields: [leader_id], references: [id])
  job              Job                  @relation(fields: [job_id], references: [id])
  groupMembers     WorkerGroupMember[]
}

model Availability {
  id         Int      @id @default(autoincrement())
  worker_id  Int
  start_time DateTime
  end_time   DateTime
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  worker     User     @relation(fields: [worker_id], references: [id])
}

model WorkerGroupMember {
  id               Int          @id @default(autoincrement())
  worker_entity_id Int
  worker_id        Int
  workerEntity     WorkerEntity @relation(fields: [worker_entity_id], references: [id])
  worker           User         @relation(fields: [worker_id], references: [id])
}


model TrustFund {
  id        Int      @id @default(autoincrement())
  balance   Float    @default(0)
  createdAt DateTime @default(now())
}

model AuctionBid {
  id         Int      @id @default(autoincrement())
  job_id     Int
  worker_id  Int
  pitch      String
  confidence Int
  created_at DateTime @default(now())
  job        Job      @relation(fields: [job_id], references: [id])
  worker     User     @relation(fields: [worker_id], references: [id])
}

model WorkerSchedule {
  id          Int    @id @default(autoincrement())
  worker_id   Int
  day_of_week Int
  start_time  String
  end_time    String
  worker      User   @relation(fields: [worker_id], references: [id])
}

model PaymentTransaction {
  id          Int      @id @default(autoincrement())
  user_id     Int
  amount      Float
  type        String
  status      String
  razorpay_id String?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

model WithdrawalRequest {
  id        Int      @id @default(autoincrement())
  user_id   Int
  amount    Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [id])
}
